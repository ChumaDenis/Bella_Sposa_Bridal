:{$PORT}

root * /srv
encode gzip

handle /sitemap.xml {
	rewrite * /api/sitemap.xml
	reverse_proxy {$API_ORIGIN} {
		header_up Host {upstream_hostport}
	}
}

handle {
	@static {
		path *.js *.css *.woff2 *.woff *.png *.jpg *.jpeg *.webp *.svg *.ico
		not path /env.js
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	@env path /env.js
	header @env Cache-Control "no-cache"

	try_files {path} /index.html
	file_server
}
